# Copy to .env (gitignored) and fill in. NEVER commit real keys.

# LLM authoring (optional). If set, the worker's /author endpoint and the
# `npm run brief` demo use the LLM author; otherwise the offline template author.
# Preference order: OpenRouter > Anthropic > template.
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-oss-120b
# ANTHROPIC_API_KEY=

# Narration voice / TTS (optional). If a key/provider is set, lessons get a real
# spoken narration track; otherwise the offline tone provider is used. Preference:
# SHOWMAN_TTS_PROVIDER override > OPENAI_API_KEY > ELEVENLABS_API_KEY > tone.
# OPENAI_API_KEY=
# ELEVENLABS_API_KEY=
# SHOWMAN_TTS_PROVIDER=          # openai | elevenlabs | kokoro | tone | silent
# SHOWMAN_TTS_VOICE=             # nova (OpenAI) / voice id (ElevenLabs) / af_heart (Kokoro)
# SHOWMAN_TTS_MODEL=            # gpt-4o-mini-tts / eleven_turbo_v2_5 / Kokoro repo id
# SHOWMAN_TTS_CACHE=./data/tts-cache   # content-addressed clip cache (reproducible, free on repeat)
# SHOWMAN_TTS_MAX_CHARS=20000   # per-render cost guard
#
# Kokoro = FREE local neural TTS. Install once: `npm install kokoro-js`. Then set
# SHOWMAN_TTS_PROVIDER=kokoro. It runs on your GPU if available (tries CUDA → WebGPU
# → CPU) and prints the device it loaded on. For an NVIDIA card, KOKORO_DEVICE=cuda
# needs a CUDA-enabled onnxruntime (CUDA 12 + cuDNN); KOKORO_DEVICE=webgpu is the
# easier GPU path. KOKORO_DTYPE=fp16 (or q4f16) is a good GPU precision.
# KOKORO_DEVICE=               # cuda | webgpu | cpu  (default: try GPU then CPU)
# KOKORO_DTYPE=                # q8 (default) | fp16 | fp32 | q4f16
# KOKORO_MODEL=                # default onnx-community/Kokoro-82M-v1.0-ONNX

# --- Image generation (optional, for generated illustrations behind the asset store) ---
# Without a key, the free deterministic placeholder generator is used (CI + offline dev).
# SHOWMAN_IMAGE_API_KEY=        # falls back to OPENAI_API_KEY
# SHOWMAN_IMAGE_API_URL=        # default https://api.openai.com/v1/images/generations
#                              #  (point at a local/self-hosted OpenAI-compatible endpoint to avoid API cost)
# SHOWMAN_IMAGE_MODEL=          # default gpt-image-1
# SHOWMAN_IMAGE_SIZE=           # default 512x512

# Service config (optional)
# PORT=8080
# SHOWMAN_DATA_DIR=./data
# SHOWMAN_CONCURRENCY=8
